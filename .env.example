# ──────────────────────────────────────────────────────────────────────────
# Bel-la Monde Riverside — environment variables
# Copy to .env.local and fill in. Vars prefixed NEXT_PUBLIC_ ship to the browser.
# ──────────────────────────────────────────────────────────────────────────

# Canonical site origin (metadata, OG images, sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.bellamonde.com

# Booking-engine handoff. The booking widget appends dates/guests as query
# params and opens this URL in a new tab. No reservation logic lives in this app.
NEXT_PUBLIC_BOOKING_ENGINE_URL=

# WhatsApp business number, E.164 digits only (e.g. 919876543210).
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Enquiry webhook (SERVER-ONLY, not exposed to the browser). Wedding/corporate/
# contact forms POST to /api/enquiry, which forwards to this URL (e.g. Make.com).
ENQUIRY_WEBHOOK_URL=

# Analytics (wired in Phase 7). Leave blank to disable a given tag.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GADS_ID=
